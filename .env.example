APP_NAME="Store Agent"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Application Mode (DEV or PROD)
MODE=DEV

# Server Port
PORT=8000

# Database (MySQL)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=store_agent
DB_USERNAME=root
DB_PASSWORD=

# OpenRouter LLM
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=your_model_name

# Pinecone Vector Database
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=clothing-store-index

# Facebook/Meta Integration
FB_VERIFY_TOKEN=your_verify_token
FB_PAGE_ACCESS_TOKEN=your_page_access_token
FB_APP_ID=your_app_id

# CashUp Payment Gateway
CASHUP_API_URL=https://api.cashup.com/
CASHUP_API_KEY=your_cashup_api_key
CASHUP_APP_ID=your_cashup_app_id

# Gravoni Store API
GRAVONI_API_URL=https://app.gravoni.com

# Facebook Testers (comma-separated PSIDs - DEV mode only)
TESTERS_FACEBOOK_IDS=id1,id2,id3

# API Authentication Key for Gravoni
API_SECRET_KEY=your_api_secret_key

# Auto-reply to comments (default: false)
AUTO_REPLY_COMMENTS_ENABLED=false

# Queue Connection
QUEUE_CONNECTION=database

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

IG_ACCESS_TOKEN=
